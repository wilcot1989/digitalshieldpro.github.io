<!doctype html>
<html lang="en">
<head>
	<style type='text/css'>
		.centerme {
			position: fixed;
			top: 50%;
			left: 50%;
			margin-top: -200px;
			margin-left: -350px;
			font-family: sans-serif;
			font-size: 11px;
			color: #bbb;
		}

    @media (prefers-color-scheme: dark) {
      	body{background:#000;}
      	.centerme {filter: invert(1);color: #888;}
    }

	</style>
</head>
<body>
	<div class="centerme" style="text-align: center;">
		<img  src="/404/peugeot-404.png" alt="404 error"/>
		<br>Peugeot 404 : 1960 > 1975
	</div>
</body>
</html>